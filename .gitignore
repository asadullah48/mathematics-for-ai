*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Jupyter Notebook
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# Type checking
.mypy_cache/

# Documentation
docs/_build/
site/

# Data files (large datasets)
data/large-datasets/
*.pkl
*.h5
*.hdf5
!data/sample-datasets/.gitkeep

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
~*

# Secrets
.env.local
.env.*.local
secrets/
*.key
*.pem

# Model checkpoints
models/checkpoints/
*.pt
*.pth
*.onnx

# Animation outputs
*.gif
*.mp4
!docs/animations/.gitkeep
